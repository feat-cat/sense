# ===========================================
# Sense - 多模态桥接 Skill 配置
# 复制此文件为 .env 并填写
# ===========================================

# ── 必填 ──────────────────────────────────

API_KEY=sk-your-api-key-here          # API 密钥
BASE_URL=https://api.openai.com/v1     # API 地址（脚本拼接 /chat/completions）
MODEL_ID=gpt-4o                        # 模型 ID
DATA_PATH=./conversations              # 对话数据存储路径（. = 执行命令的工作目录，不是脚本目录！建议用绝对路径如 D:\data\sense）

# ── 通用可选 ──────────────────────────────

SINGLE_FILE_ONLY=false                 # true=每个对话全程最多1个文件  (默认 false)
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.bmp,.webp,.svg,.mp4,.mov,.avi,.mkv,.webm,.mp3,.wav,.m4a,.ogg,.flac,.pdf
TEMPERATURE=0.7                        # 模型温度     (默认 0.7)
MAX_TOKENS=4096                        # 最大输出token (默认 4096)
TOP_P=1.0                              # Top-p 采样   (默认 1.0)

# ── 视频 ──────────────────────────────────

VIDEO_MODE=native                      # native=服务端抽帧  extract=本地ffmpeg抽帧  (默认 native)
USE_AUDIO_IN_VIDEO=true                # 同时处理视频中的音频  (默认 true, 仅native模式)

# ── FFmpeg ────────────────────────────────

FFMPEG_ENABLED=true                    # 启用ffmpeg（音频转码+视频抽帧用）  (默认 true)
VIDEO_FRAME_INTERVAL=2.0               # 抽帧间隔秒数  (默认 2.0)
VIDEO_MAX_FRAMES=10                    # 最大帧数     (默认 10)
VIDEO_MAX_WIDTH=1024                   # 帧最大宽度px  (默认 1024)
AUDIO_TARGET_FORMAT=mp3                # 音频转码格式  (默认 mp3)
AUDIO_SAMPLE_RATE=16000                # 音频采样率    (默认 16000)

# ── media:// 路径映射 ────────────────────

OPENCLAW_MEDIA_DIR=                    # media:// 伪路径的根目录。当 AI 收到
                                       # media://xxx 路径时，从这里找真实文件。
                                       # 支持 ~ 代表用户目录。
                                       # 留空则自动搜索默认位置：
                                       #   ~/.openclaw/media/
                                       #   ~/.openclaw/workspace/media/
                                       # 示例: ~/.openclaw/media
